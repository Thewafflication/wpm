{
    "version": 3,
    "configurePresets": [
        {
            "name": "windows-base",
            "hidden": true,
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "x64-debug",
            "displayName": "x64 Debug",
            "inherits": "windows-base",
            "architecture": {
                "value": "x64"
            },
            "cacheVariables": {
                "WPM_ARCH": "x64",
                "WPM_THIRD_PARTY_ARCH": "x64"
            }
        },
        {
            "name": "x64-release",
            "displayName": "x64 Release",
            "inherits": "x64-debug"
        },
        {
            "name": "x86-debug",
            "displayName": "x86 Debug",
            "inherits": "windows-base",
            "architecture": {
                "value": "Win32"
            },
            "cacheVariables": {
                "WPM_ARCH": "x86",
                "WPM_THIRD_PARTY_ARCH": "x86"
            }
        },
        {
            "name": "x86-release",
            "displayName": "x86 Release",
            "inherits": "x86-debug"
        },
        {
            "name": "arm64-debug",
            "displayName": "ARM64 Debug",
            "inherits": "windows-base",
            "architecture": {
                "value": "ARM64"
            },
            "cacheVariables": {
                "WPM_ARCH": "arm64",
                "WPM_THIRD_PARTY_ARCH": "arm64"
            }
        },
        {
            "name": "arm64-release",
            "displayName": "ARM64 Release",
            "inherits": "arm64-debug"
        },
        {
            "name": "linux-debug",
            "displayName": "Linux Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "vendor": {
                "microsoft.com/VisualStudioRemoteSettings/CMake/1.0": {
                    "sourceDir": "$env{HOME}/.vs/$ms{projectDirName}"
                }
            }
        },
        {
            "name": "macos-debug",
            "displayName": "macOS Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "vendor": {
                "microsoft.com/VisualStudioRemoteSettings/CMake/1.0": {
                    "sourceDir": "$env{HOME}/.vs/$ms{projectDirName}"
                }
            }
        }
    ],
    "buildPresets": [
        {
            "name": "build-x64-debug",
            "displayName": "Build x64 Debug",
            "configurePreset": "x64-debug",
            "configuration": "Debug"
        },
        {
            "name": "build-x64-release",
            "displayName": "Build x64 Release",
            "configurePreset": "x64-release",
            "configuration": "Release"
        },
        {
            "name": "build-x86-debug",
            "displayName": "Build x86 Debug",
            "configurePreset": "x86-debug",
            "configuration": "Debug"
        },
        {
            "name": "build-x86-release",
            "displayName": "Build x86 Release",
            "configurePreset": "x86-release",
            "configuration": "Release"
        },
        {
            "name": "build-arm64-debug",
            "displayName": "Build ARM64 Debug",
            "configurePreset": "arm64-debug",
            "configuration": "Debug"
        },
        {
            "name": "build-arm64-release",
            "displayName": "Build ARM64 Release",
            "configurePreset": "arm64-release",
            "configuration": "Release"
        }
    ]
}
